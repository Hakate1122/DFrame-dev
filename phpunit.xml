<?xml version="1.0" encoding="UTF-8"?>
<phpunit bootstrap="vendor/autoload.php" colors="true" verbose="true">
    <testsuites>
        <testsuite name="DLight Test Suite">
            <directory>./tests</directory>
        </testsuite>
    </testsuites>

    <logging>
        <!-- Default JUnit log file (Test command will override when needed) -->
        <log type="junit" target="phpunit-report.xml"/>
    </logging>

    <php>
        <env name="APP_ENVIRONMENT" value="testing"/>
        <env name="APP_DEBUG" value="true"/>
    </php>
</phpunit>
